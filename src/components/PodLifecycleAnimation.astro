---
/**
 * PodLifecycleAnimation — Kubernetes pod lifecycle animated diagram.
 *
 * Refactored in Phase 1 onto the Vv* primitives at src/components/visuals/.
 * Public import path (src/components/PodLifecycleAnimation.astro) unchanged per D-24,
 * so MDX consumers (src/content/blog/en/2026-03-20-karpenter-right-sizing.mdx) are
 * not edited. Same viewBox (1800×820), same 7 nodes, same 7 wires, same 7 packets,
 * same delays, same tone palette — all coordinates and timings are byte-for-byte
 * identical to the pre-refactor implementation.
 *
 * Wire endpoints use fromPoint/toPoint overrides where the pre-refactor diagram
 * exited/entered nodes at edge-midpoints instead of mathematical ray-to-rect
 * intersections. This preserves pixel parity; see Plan 06 README for why authors
 * should prefer default edge-points in new diagrams.
 */
import VvStage from './visuals/VvStage.astro';
import VvNode from './visuals/VvNode.astro';
import VvWire from './visuals/VvWire.astro';
import VvPacket from './visuals/VvPacket.astro';

interface Props {
  caption?: string;
  title?: string;
}

const {
  title = 'Pod lifecycle · scheduler to Ready',
  caption = 'kubectl → API server → etcd · scheduler picks node · kubelet spawns pods',
} = Astro.props;
---

<VvStage title={title} caption={caption}>
  {/* 7 nodes — coordinates from pre-refactor percent math: x=left%*1800, y=top%*820 */}
  <VvNode id="kubectl" x={60} y={330} label="kubectl" tone="teal" animation="slide-x" delay={0}>
    <svg viewBox="0 0 24 24" fill="none" stroke="var(--brand-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>
  </VvNode>

  <VvNode id="api" x={360} y={330} label="API server" tone="teal" animation="pop" delay={300}>
    <svg viewBox="0 0 24 24" fill="none" stroke="var(--brand-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5"></polygon><polygon points="12 6 18 9.5 18 14.5 12 18 6 14.5 6 9.5"></polygon><line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"></line><line x1="2" y1="8.5" x2="6" y2="9.5"></line><line x1="18" y1="9.5" x2="22" y2="8.5"></line><line x1="2" y1="15.5" x2="6" y2="14.5"></line><line x1="18" y1="14.5" x2="22" y2="15.5"></line></svg>
  </VvNode>

  <VvNode id="etcd" x={660} y={130} label="etcd" tone="teal" animation="drop" delay={600}>
    <svg viewBox="0 0 24 24" fill="none" stroke="var(--brand-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5v14a9 3 0 0 0 18 0V5"></path><path d="M3 12a9 3 0 0 0 18 0"></path></svg>
  </VvNode>

  <VvNode id="scheduler" x={660} y={530} label="scheduler" tone="teal" animation="drop" delay={900}>
    <svg viewBox="0 0 24 24" fill="var(--brand-primary)" aria-hidden="true"><path d="M12 2a5 5 0 0 0-5 5c0 1 .3 2 .8 2.8A4 4 0 0 0 5 13.5C5 16 7 18 9.5 18H10v2a2 2 0 0 0 4 0v-2h.5c2.5 0 4.5-2 4.5-4.5a4 4 0 0 0-2.8-3.7c.5-.8.8-1.8.8-2.8a5 5 0 0 0-5-5z"></path></svg>
  </VvNode>

  <VvNode id="kubelet" x={960} y={330} label="kubelet" tone="teal" animation="pop" delay={1200}>
    <svg viewBox="0 0 32 32" fill="none" stroke="var(--brand-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 3 4 9v14l12 6 12-6V9L16 3z" fill="rgba(245,158,11,0.18)"/><path d="M4 9l12 6 12-6"/><path d="M16 15v14"/></svg>
  </VvNode>

  <VvNode id="podA" x={1300} y={190} label="Pod A" tone="amber" animation="pop" delay={1500}>
    <svg viewBox="0 0 32 32" fill="none" stroke="var(--brand-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 3 4 9v14l12 6 12-6V9L16 3z" fill="rgba(245,158,11,0.18)"/><path d="M4 9l12 6 12-6"/><path d="M16 15v14"/></svg>
  </VvNode>

  <VvNode id="podB" x={1300} y={470} label="Pod B" tone="amber" animation="pop" delay={1700}>
    <svg viewBox="0 0 32 32" fill="none" stroke="var(--brand-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 3 4 9v14l12 6 12-6V9L16 3z" fill="rgba(245,158,11,0.18)"/><path d="M4 9l12 6 12-6"/><path d="M16 15v14"/></svg>
  </VvNode>

  {/* 7 wires — fromPoint/toPoint overrides preserve pre-refactor midpoint-based endpoints exactly */}
  <VvWire from="kubectl" to="api" delay={700} fromPoint={[280, 410]} toPoint={[360, 410]}/>
  <VvWire from="api" to="etcd" delay={1000} fromPoint={[580, 410]} toPoint={[660, 210]}/>
  <VvWire from="api" to="scheduler" delay={1300} fromPoint={[580, 410]} toPoint={[660, 610]}/>
  <VvWire from="etcd" to="kubelet" delay={1600} dashed fromPoint={[880, 210]} toPoint={[960, 410]}/>
  <VvWire from="scheduler" to="kubelet" delay={1600} dashed fromPoint={[880, 610]} toPoint={[960, 410]}/>
  <VvWire from="kubelet" to="podA" delay={1900} tone="amber" fromPoint={[1180, 410]} toPoint={[1300, 270]}/>
  <VvWire from="kubelet" to="podB" delay={2100} tone="amber" fromPoint={[1180, 410]} toPoint={[1300, 550]}/>

  {/* 7 packets */}
  <VvPacket wire="kubectl-api" duration="1.4s" delay="1.2s"/>
  <VvPacket wire="api-etcd" duration="1.4s" delay="1.5s"/>
  <VvPacket wire="api-scheduler" duration="1.4s" delay="1.8s"/>
  <VvPacket wire="etcd-kubelet" duration="1.5s" delay="2.1s"/>
  <VvPacket wire="scheduler-kubelet" duration="1.5s" delay="2.3s"/>
  <VvPacket wire="kubelet-podA" duration="1.3s" delay="2.4s" r={11} tone="amber"/>
  <VvPacket wire="kubelet-podB" duration="1.3s" delay="2.6s" r={11} tone="amber"/>
</VvStage>
