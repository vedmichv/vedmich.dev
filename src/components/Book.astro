---
import { t, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
const amazonUrl = 'https://www.amazon.com/dp/1835460038';
---

<section id="book" class="py-20 sm:py-28 bg-surface/30">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <h2 class="text-3xl font-bold mb-12 animate-on-scroll">{i.book.title}</h2>

    <div class="animate-on-scroll">
      <a
        href={amazonUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group block p-6 sm:p-8 rounded-xl bg-bg border border-border card-glow max-w-2xl"
      >
        <div class="flex flex-col sm:flex-row gap-6">
          <!-- Book icon placeholder -->
          <div class="w-32 h-44 rounded-lg bg-gradient-to-br from-accent/20 to-warm/20 border border-border flex items-center justify-center shrink-0">
            <svg class="w-12 h-12 text-accent/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>

          <div>
            <h3 class="text-xl font-semibold mb-3 group-hover:text-accent transition-colors">
              {i.book.name}
            </h3>
            <p class="text-text-muted text-sm leading-relaxed mb-4">
              {i.book.desc}
            </p>
            <span class="inline-flex items-center gap-2 text-sm font-medium text-accent group-hover:text-accent-light transition-colors">
              {i.book.cta}
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </span>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>
