---
import { t, type Locale, getAlternateLocale, getLocalizedPath } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
const altLocale = getAlternateLocale(locale);

// Anchor nav targets live on the homepage. When rendered on a subpage
// (e.g. /en/blog/<slug>/), bare `#anchor` hrefs stay on that subpage —
// so prefix with the localized home path to route back to the section.
const homePath = getLocalizedPath('/', locale);
const currentPath = Astro.url.pathname;
const isHome = currentPath === homePath || currentPath === `${homePath}index.html`;
const anchorPrefix = isHome ? '' : homePath;

const navItems = [
  { href: `${anchorPrefix}#about`, label: i.nav.about },
  { href: `${anchorPrefix}#podcasts`, label: i.nav.podcasts },
  { href: `${anchorPrefix}#book`, label: i.nav.book },
  { href: `${anchorPrefix}#speaking`, label: i.nav.speaking },
  { href: `${anchorPrefix}#presentations`, label: i.nav.presentations },
  { href: `${anchorPrefix}#blog`, label: i.nav.blog },
  { href: `${anchorPrefix}#contact`, label: i.nav.contact },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-border/50 backdrop-blur-md bg-bg/80" id="site-header">
  <nav class="max-w-[1120px] mx-auto px-6 py-[14px] flex items-center justify-between gap-6">
    <!-- Logo -->
    <a href={getLocalizedPath('/', locale)} class="flex items-center gap-2.5 group">
      <img src="/favicon.svg" alt="VV" width="32" height="32" class="w-8 h-8 rounded-[7px] shrink-0" />
      <span class="font-display font-bold text-base text-text-primary group-hover:text-brand-primary transition-colors tracking-tight">
        vedmich.dev
      </span>
    </a>

    <!-- Desktop nav (center) -->
    <ul class="hidden md:flex items-center gap-6">
      {navItems.map(({ href, label }) => (
        <li>
          <a href={href} class="font-body text-sm font-medium text-text-secondary hover:text-brand-primary transition-colors">
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right: search + lang -->
    <div class="hidden md:flex items-center gap-2">
      <!-- Search trigger — opens ⌘K palette -->
      <button
        type="button"
        id="search-trigger-desktop"
        aria-label={i.nav.search_label}
        class="flex items-center gap-2.5 bg-bg-base border border-border hover:border-brand-primary hover:text-text-primary pl-2.5 pr-2 py-1.5 rounded-[7px] text-[13px] text-text-secondary transition-colors cursor-pointer"
      >
        <span class="font-mono text-[13px] text-brand-primary leading-none">⌕</span>
        <span>{i.nav.search_placeholder}</span>
        <kbd class="font-mono text-[10px] text-text-muted bg-surface border border-border rounded-[3px] px-1.5 py-[1px] leading-none">⌘K</kbd>
      </button>

      <!-- Locale switcher: EN · RU as a single button -->
      <div class="flex items-center font-mono text-xs border border-border rounded-md overflow-hidden">
        <a
          href={getLocalizedPath('/', 'en')}
          class={`lang-switch px-2.5 py-1.5 transition-colors ${locale === 'en' ? 'text-text-primary bg-surface' : 'text-text-secondary hover:text-text-primary'}`}
          data-lang="en"
          aria-current={locale === 'en' ? 'page' : undefined}
        >EN</a>
        <span class="text-border-strong select-none px-0" aria-hidden="true">·</span>
        <a
          href={getLocalizedPath('/', 'ru')}
          class={`lang-switch px-2.5 py-1.5 transition-colors ${locale === 'ru' ? 'text-text-primary bg-surface' : 'text-text-secondary hover:text-text-primary'}`}
          data-lang="ru"
          aria-current={locale === 'ru' ? 'page' : undefined}
        >RU</a>
      </div>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-text-muted hover:text-text transition-colors"
      aria-label="Menu"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border/50 bg-bg/95 backdrop-blur-md">
    <ul class="px-4 py-4 space-y-3">
      {navItems.map(({ href, label }) => (
        <li>
          <a href={href} class="block text-sm text-text-muted hover:text-text transition-colors">
            {label}
          </a>
        </li>
      ))}
      <li class="pt-3 border-t border-border/50">
        <button
          type="button"
          id="search-trigger-mobile"
          aria-label={i.nav.search_label}
          class="w-full flex items-center gap-2 text-sm text-text-muted hover:text-text-primary transition-colors py-1"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="7" />
            <path stroke-linecap="round" d="m20 20-3-3" />
          </svg>
          <span>{i.nav.search_placeholder}</span>
        </button>
      </li>
      <li class="flex items-center gap-2 text-sm">
        <a
          href={getLocalizedPath('/', 'en')}
          class={`lang-switch transition-colors ${locale === 'en' ? 'font-semibold text-text-primary' : 'text-text-muted'}`}
          data-lang="en"
        >EN</a>
        <span class="text-border-strong" aria-hidden="true">·</span>
        <a
          href={getLocalizedPath('/', 'ru')}
          class={`lang-switch transition-colors ${locale === 'ru' ? 'font-semibold text-text-primary' : 'text-text-muted'}`}
          data-lang="ru"
        >RU</a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Close mobile menu on link click
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });

  // Header shrink on scroll
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('shadow-lg');
    } else {
      header?.classList.remove('shadow-lg');
    }
  });

  // Save language preference on switch
  document.querySelectorAll('.lang-switch').forEach((link) => {
    link.addEventListener('click', () => {
      const lang = (link as HTMLElement).dataset.lang;
      if (lang) localStorage.setItem('vedmich-lang', lang);
    });
  });

  // Wire search triggers → SearchPalette (listens for `vv:search:open`)
  const searchTriggerDesktop = document.getElementById('search-trigger-desktop');
  const searchTriggerMobile = document.getElementById('search-trigger-mobile');

  const openSearch = () => {
    document.dispatchEvent(new CustomEvent('vv:search:open'));
    menu?.classList.add('hidden');
  };

  searchTriggerDesktop?.addEventListener('click', openSearch);
  searchTriggerMobile?.addEventListener('click', openSearch);
</script>

<script>
  // Nav active-state highlight via IntersectionObserver (Phase 4 D-09).
  // Observes every <section id="..."> on the page and toggles `.is-active`
  // on the matching header anchor. Single observer, no framework, extends
  // Zero-JS baseline by one per D-10.
  const sections = document.querySelectorAll('section[id]');
  const navLinks = Array.from(document.querySelectorAll('header a[href^="#"]'));
  const linkByHref = new Map(navLinks.map((a) => [a.getAttribute('href'), a]));

  const obs = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        const link = linkByHref.get('#' + (e.target as HTMLElement).id);
        if (!link) continue;
        if (e.isIntersecting) {
          navLinks.forEach((a) => a.classList.remove('is-active'));
          link.classList.add('is-active');
        }
      }
    },
    { threshold: 0.5, rootMargin: '-80px 0px -50% 0px' }
  );

  sections.forEach((s) => obs.observe(s));
</script>

<style>
  /* Nav active-state visual: teal underline + full-contrast text (Phase 4 D-09). */
  header a.is-active {
    color: var(--text-primary);
    border-bottom: 2px solid var(--brand-primary);
  }
</style>
