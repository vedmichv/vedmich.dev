---
// Enhance all <pre> blocks inside `.prose` with a copy-to-clipboard button.
// Mounts once per page; picks up every Shiki-rendered code block Astro emits.
// The button uses Clipboard API with a graceful fallback; copy state is
// announced to screen readers via aria-live.
//
// Includes per-button localized labels so the same component serves EN + RU.

interface Props {
  locale?: 'en' | 'ru';
}

const { locale = 'en' } = Astro.props;

const labels = {
  en: { copy: 'Copy', copied: 'Copied' },
  ru: { copy: 'Копировать', copied: 'Скопировано' },
} as const;

const l = labels[locale];
---

<script is:inline data-copy-label={l.copy} data-copied-label={l.copied}>
  (() => {
    const script = document.currentScript;
    const COPY = script?.dataset.copyLabel ?? 'Copy';
    const COPIED = script?.dataset.copiedLabel ?? 'Copied';

    const pres = document.querySelectorAll('.prose pre');
    pres.forEach((pre) => {
      if (pre.parentElement?.classList.contains('code-wrap')) return;

      const wrap = document.createElement('div');
      wrap.className = 'code-wrap';
      pre.parentNode?.insertBefore(wrap, pre);
      wrap.appendChild(pre);

      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'code-copy-btn';
      btn.setAttribute('aria-label', COPY);
      btn.textContent = COPY;
      wrap.appendChild(btn);

      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        const text = code ? code.innerText : pre.innerText;
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          // Fallback: textarea selection
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.style.position = 'fixed';
          ta.style.top = '-1000px';
          document.body.appendChild(ta);
          ta.select();
          try { document.execCommand('copy'); } catch { /* noop */ }
          document.body.removeChild(ta);
        }
        btn.textContent = COPIED;
        btn.classList.add('is-copied');
        setTimeout(() => {
          btn.textContent = COPY;
          btn.classList.remove('is-copied');
        }, 1600);
      });
    });
  })();
</script>

<style is:global>
  .prose .code-wrap {
    position: relative;
  }

  .prose .code-wrap > pre {
    /* preserve whatever Shiki+Astro set */
  }

  .prose .code-copy-btn {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    padding: 0.3rem 0.6rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: var(--bg-base);
    border: 1px solid var(--border);
    border-radius: 6px;
    cursor: pointer;
    opacity: 0;
    transition: opacity 120ms ease, color 120ms ease, border-color 120ms ease, background 120ms ease;
  }

  .prose .code-wrap:hover .code-copy-btn,
  .prose .code-copy-btn:focus-visible {
    opacity: 1;
  }

  .prose .code-copy-btn:hover {
    color: var(--brand-primary);
    border-color: var(--brand-primary);
  }

  .prose .code-copy-btn.is-copied {
    color: var(--brand-primary);
    border-color: var(--brand-primary);
    background: var(--brand-primary-soft);
    opacity: 1;
  }

  /* Always visible on touch devices (no hover) */
  @media (hover: none) {
    .prose .code-copy-btn { opacity: 1; }
  }
</style>
