---
import { t, type Locale } from '../i18n/utils';
import { skills, certifications } from '../data/social';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
---

<section id="about" class="py-20 sm:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <h2 class="text-3xl font-bold mb-12 animate-on-scroll">{i.about.title}</h2>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Bio -->
      <div class="animate-on-scroll">
        <p class="text-lg text-text-muted leading-relaxed mb-8">
          {i.about.bio}
        </p>

        <!-- Skills -->
        <h3 class="text-sm font-semibold uppercase tracking-wider text-accent mb-4">{i.about.skills_title}</h3>
        <div class="flex flex-wrap gap-2">
          {skills.map((skill) => (
            <span class="px-3 py-1.5 rounded-lg text-sm bg-surface border border-border text-text-muted hover:border-accent/50 hover:text-text transition-colors">
              {skill}
            </span>
          ))}
        </div>
      </div>

      <!-- Certifications -->
      <div class="animate-on-scroll">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-accent mb-4">{i.about.certs_title}</h3>
        <div class="space-y-3">
          {certifications.map(({ name }) => (
            <div class="flex items-center gap-3 p-3 rounded-lg bg-surface border border-border">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center text-accent">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                </svg>
              </div>
              <span class="font-medium">{name}</span>
            </div>
          ))}
        </div>

        <div class="mt-6 p-4 rounded-lg bg-warm/5 border border-warm/20">
          <p class="text-sm text-warm">
            CNCF Kubernaut = all 5 Kubernetes certifications (CKA + CKS + CKAD + KCNA + KCSA)
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
