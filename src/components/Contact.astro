---
import { t, type Locale } from '../i18n/utils';
import { socialLinks } from '../data/social';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
---

<section id="contact" data-state="cta" class="py-20 sm:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="font-display text-3xl font-bold mb-3 animate-on-scroll">{i.contact.title}</h2>
    <p class="text-text-muted mb-10 animate-on-scroll">{i.contact.subtitle}</p>

    {/* Letter-badge grid — whole-card anchors per D-18/19/20/21/22 */}
    <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-8 animate-on-scroll max-w-[640px] mx-auto">
      {socialLinks.map(({ name, url }) => {
        const letter = name.startsWith('X') ? '𝕏' : name[0];
        const displayName = name.startsWith('X') ? 'X' : name;
        return (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex flex-col items-center justify-center gap-2 p-5 rounded-[10px] bg-bg-base border border-border card-glow"
            aria-label={`${displayName} (opens in new tab)`}
          >
            <span class="font-display text-[22px] font-bold text-brand-primary leading-none">{letter}</span>
            <span class="font-body text-[13px] text-text-primary">{displayName}</span>
          </a>
        );
      })}
    </div>

    {/* CTA state — primary teal button + noscript fallback (D-23/24/35) */}
    <div class="mt-8 animate-on-scroll" data-contact-cta-wrapper>
      <button
        type="button"
        data-contact-open-form
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-brand-primary text-bg-base font-body text-[15px] font-medium hover:bg-brand-primary-hover transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2 focus-visible:ring-offset-bg-base"
      >
        {i.contact.write_me_cta}
      </button>
      <noscript>
        <a
          href="mailto:viktor@vedmich.dev"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-brand-primary text-bg-base font-body text-[15px] font-medium hover:bg-brand-primary-hover transition-colors"
        >
          {i.contact.write_me_cta}
        </a>
      </noscript>
    </div>

    {/* Form state — Card with Name / Email / Message / Send / Cancel (D-25/26/27/28) */}
    <div class="max-w-[480px] mx-auto mt-8 p-6 rounded-xl bg-bg-surface border border-border text-left" data-contact-form-wrapper>
      <form data-contact-form class="flex flex-col gap-[14px]">
        <label class="flex flex-col gap-[6px]">
          <span class="font-body text-[13px] font-medium text-text-primary">{i.contact.form.name_label}</span>
          <input
            required
            type="text"
            name="name"
            minlength="1"
            placeholder={i.contact.form.name_placeholder}
            class="bg-bg-base text-text-primary border border-border rounded-lg px-[14px] py-[10px] font-body text-[15px] outline-none focus-visible:border-brand-primary focus-visible:ring-1 focus-visible:ring-brand-primary/40 placeholder:text-text-muted"
          />
        </label>
        <label class="flex flex-col gap-[6px]">
          <span class="font-body text-[13px] font-medium text-text-primary">{i.contact.form.email_label}</span>
          <input
            required
            type="email"
            name="email"
            placeholder={i.contact.form.email_placeholder}
            class="bg-bg-base text-text-primary border border-border rounded-lg px-[14px] py-[10px] font-body text-[15px] outline-none focus-visible:border-brand-primary focus-visible:ring-1 focus-visible:ring-brand-primary/40 placeholder:text-text-muted"
          />
        </label>
        <label class="flex flex-col gap-[6px]">
          <span class="font-body text-[13px] font-medium text-text-primary">{i.contact.form.message_label}</span>
          <textarea
            required
            name="message"
            rows="4"
            minlength="10"
            placeholder={i.contact.form.message_placeholder}
            class="bg-bg-base text-text-primary border border-border rounded-lg px-[14px] py-[10px] font-body text-[15px] outline-none focus-visible:border-brand-primary focus-visible:ring-1 focus-visible:ring-brand-primary/40 placeholder:text-text-muted resize-y"
          ></textarea>
        </label>
        <div class="flex gap-[10px] mt-1.5">
          <button
            type="submit"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-brand-primary text-bg-base font-body text-[15px] font-medium hover:bg-brand-primary-hover transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2 focus-visible:ring-offset-bg-base"
          >
            {i.contact.form.send}
          </button>
          <button
            type="button"
            data-contact-cancel
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-transparent text-text-primary border border-border hover:border-brand-primary font-body text-[15px] font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2 focus-visible:ring-offset-bg-base"
          >
            {i.contact.form.cancel}
          </button>
        </div>
      </form>
    </div>

    {/* Success state — honest copy per D-13/14/15/16 */}
    <div class="max-w-[480px] mx-auto mt-8 p-6 rounded-xl bg-bg-surface border border-border" data-contact-success-wrapper>
      <div class="text-center py-5">
        <div class="font-mono text-[32px] text-brand-primary leading-none" aria-hidden="true">✓</div>
        <h3 class="font-display text-[20px] text-text-primary my-2">{i.contact.success.heading}</h3>
        <p class="font-body text-text-muted m-0">{i.contact.success.body}</p>
        <button
          type="button"
          data-contact-close-success
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-transparent text-text-primary border border-border hover:border-brand-primary font-body text-[15px] font-medium transition-colors mt-4 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2 focus-visible:ring-offset-bg-base"
        >
          {i.contact.success.close}
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  /* D-32: visibility controlled via [data-state] on the section root.
     Only one of CTA / form / success is visible at a time. */
  #contact[data-state="cta"] [data-contact-form-wrapper],
  #contact[data-state="cta"] [data-contact-success-wrapper] {
    display: none;
  }
  #contact[data-state="form"] [data-contact-cta-wrapper],
  #contact[data-state="form"] [data-contact-success-wrapper] {
    display: none;
  }
  #contact[data-state="success"] [data-contact-cta-wrapper],
  #contact[data-state="success"] [data-contact-form-wrapper] {
    display: none;
  }
</style>

<script>
  type ContactState = 'cta' | 'form' | 'success';

  const section = document.getElementById('contact');
  const openBtn = section?.querySelector<HTMLButtonElement>('[data-contact-open-form]');
  const form = section?.querySelector<HTMLFormElement>('[data-contact-form]');
  const cancelBtn = section?.querySelector<HTMLButtonElement>('[data-contact-cancel]');
  const closeBtn = section?.querySelector<HTMLButtonElement>('[data-contact-close-success]');
  const nameInput = form?.querySelector<HTMLInputElement>('input[name="name"]');

  if (section && openBtn && form && cancelBtn && closeBtn && nameInput) {
    function setState(next: ContactState): void {
      section!.setAttribute('data-state', next);
      if (next === 'form') {
        // Match SearchPalette focus pattern — 10ms defer so display toggle completes.
        setTimeout(() => nameInput!.focus(), 10);
      }
    }

    openBtn.addEventListener('click', () => setState('form'));
    cancelBtn.addEventListener('click', () => setState('cta'));
    closeBtn.addEventListener('click', () => setState('cta'));

    form.addEventListener('submit', (e) => {
      // Native HTML5 validation runs FIRST. If invalid, the browser blocks
      // submit and this handler never fires (D-11 — validation enabled).
      e.preventDefault();

      const fd = new FormData(form!);
      const name = String(fd.get('name') || '').trim();
      const email = String(fd.get('email') || '').trim();
      const message = String(fd.get('message') || '');

      const subject = name
        ? `vedmich.dev — ${name}`
        : 'vedmich.dev — Contact';
      const body = `From: ${name} <${email}>\n\n${message}`;

      // T-10-01 mitigation: encodeURIComponent on EVERY interpolated value.
      // Prevents CRLF / & / ; injection into mail headers.
      // Recipient is inlined as a literal string (D-01/D-03) — no interpolation.
      const mailto =
        `mailto:viktor@vedmich.dev` +
        `?subject=${encodeURIComponent(subject)}` +
        `&body=${encodeURIComponent(body)}`;

      window.location.href = mailto;
      setState('success');
    });

    // D-34: ESC scoped to the section, NOT document — avoids conflict with
    // SearchPalette's global ESC handler.
    section.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      const state = section!.getAttribute('data-state');
      if (state === 'form' || state === 'success') {
        e.preventDefault();
        setState('cta');
      }
    });
  }
</script>
