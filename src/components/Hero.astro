---
import { t, type Locale } from '../i18n/utils';
import { certifications } from '../data/social';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
---

<section class="hero-deep-signal noise-overlay relative min-h-[90vh] flex items-center pt-16 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 w-full">
    <div class="max-w-3xl">
      <!-- Terminal prompt: ~/vedmich.dev $ whoami -->
      <div class="font-mono text-sm text-text-muted mb-4 flex items-center gap-2">
        <span class="text-accent-light">~/vedmich.dev $</span>
        <span>whoami</span>
      </div>

      <!-- Greeting -->
      <p class="font-mono text-sm text-text-muted mb-3">{i.hero.greeting}</p>

      <!-- Name with inline cursor -->
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold mb-4 tracking-tight">
        {i.hero.name}<span class="typing-cursor text-brand-primary-hover"></span>
      </h1>

      <p class="font-mono text-xl sm:text-2xl text-warm-light font-medium mb-3">
        {i.hero.role}
      </p>

      <p class="text-lg text-text-muted mb-8">
        {i.hero.tagline}
      </p>

      <!-- Cert badges: first one is "active" (dot + teal fill), rest outline -->
      <div class="flex flex-wrap gap-2 mb-10">
        {certifications.map(({ name }, idx) => (
          idx === 0 ? (
            <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium bg-brand-primary-soft border border-brand-primary text-brand-primary-hover">
              <span class="w-1.5 h-1.5 rounded-full bg-brand-primary-hover"></span>
              {name}
            </span>
          ) : (
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-transparent border border-border text-text-secondary">
              {name}
            </span>
          )
        ))}
      </div>

      <!-- CTAs: primary teal + ghost "Read more →" -->
      <div class="flex flex-wrap items-center gap-3">
        <a
          href="#contact"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-brand-primary hover:bg-brand-primary-hover text-bg font-medium rounded-lg transition-colors"
        >
          {i.hero.cta}
        </a>
        <a
          href="#about"
          class="inline-flex items-center gap-2 px-5 py-2.5 border border-border hover:border-brand-primary hover:text-brand-primary-hover text-text-primary font-medium rounded-lg transition-colors"
        >
          {i.hero.cta_secondary}
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-deep-signal {
    background: var(--grad-hero-soft);
  }
</style>
