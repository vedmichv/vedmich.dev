---
/**
 * BookLink: the "Cracking the Kubernetes Interview" cover as a clickable link
 * to the canonical Amazon listing. Used across the K8s Interview blog series
 * (EN + RU) so every post points at ONE URL; change it here and the whole series
 * updates. Mirrors the canonical link in Book.astro (homepage).
 *
 * Usage in an .mdx post:
 *   import BookLink from '../../../components/BookLink.astro';
 *   <BookLink cover="/blog-assets/<slug>/book-cover.png" locale="en" />
 *
 * `caption` defaults to the book name; pass a localized caption for RU.
 */
const AMAZON_URL = 'https://www.amazon.com/dp/1835460038';

interface Props {
  cover: string;
  locale?: 'en' | 'ru';
  caption?: string;
}

const { cover, locale = 'en', caption } = Astro.props;

const defaults = {
  en: { cap: 'Cracking the Kubernetes Interview. Get it on Amazon.', alt: 'Cracking the Kubernetes Interview, by Viktor Vedmich and Alexander Dovnar' },
  ru: { cap: '«Cracking the Kubernetes Interview». Купить на Amazon.', alt: 'Cracking the Kubernetes Interview, Виктор Ведмич и Александр Довнар' },
};
const d = defaults[locale];
const cap = caption ?? d.cap;
---
<figure class="my-6">
  <a href={AMAZON_URL} target="_blank" rel="noopener noreferrer" class="book-link" aria-label={d.alt}>
    <img
      src={cover}
      alt={d.alt}
      loading="lazy"
      width="420"
      class="book-link-img"
    />
  </a>
  <figcaption class="text-sm text-text-muted mt-2 text-center">{cap}</figcaption>
</figure>

<style>
  .book-link {
    display: block;
    width: max-content;
    margin: 0 auto;
    border-radius: 8px;
    transition: transform 350ms cubic-bezier(0.16, 1, 0.3, 1),
                filter 350ms cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }
  .book-link-img {
    display: block;
    max-width: 320px;
    height: auto;
  }
  .book-link:hover,
  .book-link:focus-visible {
    transform: translateY(-5px);
    filter: drop-shadow(0 14px 26px rgba(0, 0, 0, 0.5))
            drop-shadow(0 0 20px color-mix(in srgb, var(--brand-primary) 22%, transparent));
  }
  @media (prefers-reduced-motion: reduce) {
    .book-link,
    .book-link:hover,
    .book-link:focus-visible {
      transform: none;
      transition: none;
    }
  }
</style>
