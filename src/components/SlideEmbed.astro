---
/**
 * SlideEmbed — embed one slide of a deployed Slidev deck as a live iframe, with optional auto-loop.
 *
 * The deck is a first-party artifact served at /slides/<slug>/ (see docs/slides-onboarding.md).
 * We iframe a specific slide by URL, so the visuals are the real deck, always in sync with what's
 * deployed, and zero Slidev deps are pulled into the Astro toolchain.
 *
 * Used by blog posts that companion a deck (e.g. the Kubernetes Gateway API zero-to-hero article)
 * to reuse animation/diagram slides instead of re-drawing them. Code slides stay as Shiki blocks.
 *
 * AUTO-LOOP: pass `clicks` = the slide's total v-click steps (> 0). The runtime then drives the
 * animation on a slow loop so the reader doesn't have to click: it steps clicks 0..N by reloading
 * the iframe to /<slide>?clicks=<k> (absolute, ~100ms warm, so it never drifts into an adjacent
 * slide the way relative keypresses do — verified on the live deck), holds the final frame, resets,
 * repeats. Gated to viewport via IntersectionObserver (many SPAs must not all run off-screen) and
 * disabled under prefers-reduced-motion (shows the final, fully-revealed frame). clicks=0 (default)
 * = a plain static embed, still fully interactive by hand.
 *
 * loading="lazy" is load-bearing: a post may embed many slides, each a full SPA.
 */
interface Props {
  slug?: string;
  slide: number;
  title: string;
  caption?: string;
  clicks?: number;
}
const { slug = 'k8s-gateway-api', slide, title, caption, clicks = 0 } = Astro.props;
const base = `/slides/${slug}/${slide}`;
const src = clicks > 0 ? `${base}?clicks=0` : base;
---
<figure class="my-8">
  <div class="slide-embed">
    <iframe
      src={src}
      title={title}
      loading="lazy"
      allowfullscreen
      referrerpolicy="no-referrer"
      data-slide-embed
      data-base={base}
      data-clicks={clicks}
    ></iframe>
  </div>
  {caption && <figcaption class="text-sm text-text-muted mt-2 text-center">{caption}</figcaption>}
</figure>
<style>
  .slide-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid rgb(255 255 255 / 0.08);
    background: #0F172A;
  }
  .slide-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>

<script>
  // One initializer for every SlideEmbed on the page. Idempotent (guards a per-iframe flag).
  function initSlideEmbeds() {
    const STEP_MS = 2600;   // dwell per click step (slow + readable)
    const HOLD_MS = 4200;   // dwell on the final, fully-revealed frame
    const RESET_MS = 900;   // brief beat on the empty frame before replaying
    const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const frames = document.querySelectorAll<HTMLIFrameElement>('iframe[data-slide-embed]');
    frames.forEach((iframe) => {
      if (iframe.dataset.loopInit) return;
      const clicks = parseInt(iframe.dataset.clicks || '0', 10);
      const base = iframe.dataset.base || '';
      if (!clicks || clicks < 1 || !base) return;   // static embed, nothing to drive
      iframe.dataset.loopInit = '1';

      // reduced motion: just show the final, fully-revealed frame and stop.
      if (reduce) { iframe.src = `${base}?clicks=${clicks}`; return; }

      // Advance clicks IN-DOCUMENT (pushState + popstate) so the deck's own CSS transitions fire —
      // a real "click" fade-in, no iframe reload, no flash. Verified deterministic on the live deck:
      // vue-router reads ?clicks from the query on popstate, lands exactly on k, never overshoots into
      // an adjacent slide (which synthetic ArrowRight does). Falls back to a src reload if the iframe
      // is cross-origin (e.g. a dev preview on a different host) where contentWindow is unreachable.
      const go = (k: number) => {
        try {
          const w = iframe.contentWindow as any;
          if (w && w.history && w.location && w.location.pathname.indexOf(base) !== -1) {
            w.history.pushState(w.history.state, '', `${base}?clicks=${k}`);
            w.dispatchEvent(new PopStateEvent('popstate', { state: w.history.state }));
            return;
          }
        } catch (_) { /* cross-origin: fall through to reload */ }
        iframe.src = `${base}?clicks=${k}`;
      };

      let step = 0;
      let timer: number | undefined;
      let running = false;
      let booted = false;

      const tick = () => {
        if (!running) return;
        step += 1;
        if (step > clicks) {
          // finished a full pass: hold the final frame, then reset to empty and replay
          step = 0;
          go(clicks);
          timer = window.setTimeout(() => {
            if (!running) return;
            go(0);
            timer = window.setTimeout(tick, RESET_MS);
          }, HOLD_MS);
          return;
        }
        go(step);
        timer = window.setTimeout(tick, STEP_MS);
      };

      // Kick off as soon as the embed is on screen: show the FIRST step immediately (no dead dwell on
      // the empty frame), then continue the cadence. The iframe SPA needs a beat to boot before
      // pushState can drive it, so on first run we wait for its load; afterwards it's instant.
      const begin = () => {
        if (running) return;
        running = true;
        const fire = () => { if (!running) return; step = 1; go(1); timer = window.setTimeout(tick, STEP_MS); };
        if (booted) { fire(); }
        else {
          // wait for the iframe document to be ready, then fire the first step right away
          const onLoad = () => { booted = true; iframe.removeEventListener('load', onLoad); if (running) fire(); };
          // it may already be loaded (lazy iframe resolved while scrolling in)
          try {
            if (iframe.contentDocument && iframe.contentDocument.readyState === 'complete') { booted = true; fire(); return; }
          } catch (_) {}
          iframe.addEventListener('load', onLoad);
          // safety net: if load already fired and we missed it, fire after a short boot delay
          window.setTimeout(() => { if (running && !booted) { booted = true; fire(); } }, 1800);
        }
      };
      const halt = () => { running = false; if (timer) { clearTimeout(timer); timer = undefined; } };

      // only animate while the embed is on screen
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) begin(); else halt(); });
      }, { threshold: 0.35 });
      io.observe(iframe);
    });
  }

  initSlideEmbeds();
  // re-run for Astro view-transition navigations
  document.addEventListener('astro:page-load', initSlideEmbeds);
</script>
